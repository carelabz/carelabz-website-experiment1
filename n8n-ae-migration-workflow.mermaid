%%{ init: { 'theme': 'base', 'themeVariables': { 'primaryColor': '#0B1A2F', 'primaryTextColor': '#F8FAFC', 'primaryBorderColor': '#F97316', 'lineColor': '#F97316', 'secondaryColor': '#1E293B', 'tertiaryColor': '#FFF7ED', 'fontSize': '14px' } } }%%

flowchart TD
    %% ─────────────── TRIGGER ───────────────
    START([🚀 Manual Trigger or Webhook])
    START --> FETCH_SITEMAP

    %% ─────────────── STAGE 1: DISCOVERY ───────────────
    subgraph STAGE1["<b>Stage 1 — Page Discovery</b>"]
        direction TB
        FETCH_SITEMAP["📡 HTTP Request\n<i>Fetch carelabz.com/sitemap.xml</i>"]
        PARSE_XML["⚙️ XML Parser\n<i>Extract all /ae/ URLs</i>"]
        FILTER_AE["🔍 Filter Node\n<i>Keep only AE country pages\nExclude already-migrated URLs</i>"]
        SPLIT["↔️ Split In Batches\n<i>Process 1 page at a time\nwith 5s delay between batches</i>"]
        FETCH_SITEMAP --> PARSE_XML --> FILTER_AE --> SPLIT
    end

    %% ─────────────── STAGE 2: WP EXTRACTION ───────────────
    subgraph STAGE2["<b>Stage 2 — WordPress Content Extraction</b>"]
        direction TB
        SCRAPE_PAGE["🌐 HTTP Request\n<i>GET full HTML of WP page</i>"]
        EXTRACT_META["📋 HTML Extract\n<i>Pull meta title, description,\nOG tags, canonical, hreflang</i>"]
        EXTRACT_BODY["📝 HTML Extract\n<i>Pull main content body,\nheadings, sections, CTAs</i>"]
        EXTRACT_IMAGES["🖼️ HTML Extract\n<i>Pull all image URLs,\nalt text, captions</i>"]
        EXTRACT_FAQS["❓ HTML Extract\n<i>Pull FAQ schema or\naccordion Q&A pairs</i>"]
        EXTRACT_SCHEMA["🏷️ Code Node\n<i>Parse existing JSON-LD\nstructured data</i>"]
        MERGE_EXTRACT["🔗 Merge Node\n<i>Combine all extractions\ninto single page object</i>"]

        SCRAPE_PAGE --> EXTRACT_META
        SCRAPE_PAGE --> EXTRACT_BODY
        SCRAPE_PAGE --> EXTRACT_IMAGES
        SCRAPE_PAGE --> EXTRACT_FAQS
        SCRAPE_PAGE --> EXTRACT_SCHEMA
        EXTRACT_META --> MERGE_EXTRACT
        EXTRACT_BODY --> MERGE_EXTRACT
        EXTRACT_IMAGES --> MERGE_EXTRACT
        EXTRACT_FAQS --> MERGE_EXTRACT
        EXTRACT_SCHEMA --> MERGE_EXTRACT
    end

    %% ─────────────── STAGE 3: AI TRANSFORMATION ───────────────
    subgraph STAGE3["<b>Stage 3 — AI Content Transformation</b>"]
        direction TB
        CLASSIFY["🤖 AI Agent (Claude)\n<i>Classify page type:\nservice / category / landing</i>"]
        MAP_SLUG["⚙️ Code Node\n<i>Map old WP slug → new\n/ae/services/{category}/{slug}/</i>"]
        REWRITE_SEO["🤖 AI Agent (Claude)\n<i>Rewrite meta title + description\nfor SEO + AEO compliance\nAdd definitional lede</i>"]
        ENRICH_FAQS["🤖 AI Agent (Claude)\n<i>Expand FAQ answers to 60-80 words\nAdd 'People Also Ask' questions\nStructure for voice search</i>"]
        BUILD_JSONLD["⚙️ Code Node\n<i>Generate 5 JSON-LD schemas:\nService, FAQ, LocalBusiness,\nBreadcrumb, HowTo</i>"]
        BUILD_PAYLOAD["⚙️ Code Node\n<i>Assemble full Strapi payload\nmatching ServicePage schema</i>"]

        CLASSIFY --> MAP_SLUG --> REWRITE_SEO --> ENRICH_FAQS --> BUILD_JSONLD --> BUILD_PAYLOAD
    end

    %% ─────────────── STAGE 4: IMAGE PIPELINE ───────────────
    subgraph STAGE4["<b>Stage 4 — Image Processing</b>"]
        direction TB
        DOWNLOAD_IMG["⬇️ HTTP Request\n<i>Download images from WP</i>"]
        OPTIMIZE_IMG["🖼️ Code Node (Sharp)\n<i>Resize, compress, convert\nto WebP + AVIF</i>"]
        UPLOAD_STRAPI["📤 HTTP Request\n<i>POST /api/upload\nto Strapi Media Library</i>"]
        GET_IMG_IDS["⚙️ Code Node\n<i>Map uploaded image IDs\nback to content fields</i>"]

        DOWNLOAD_IMG --> OPTIMIZE_IMG --> UPLOAD_STRAPI --> GET_IMG_IDS
    end

    %% ─────────────── STAGE 5: STRAPI LOADING ───────────────
    subgraph STAGE5["<b>Stage 5 — Strapi CMS Loading</b>"]
        direction TB
        CHECK_EXISTS["🔍 HTTP Request\n<i>GET /api/service-pages\n?filters[slug][$eq]={slug}</i>"]
        DECIDE{{"Exists?"}}
        CREATE_ENTRY["📝 HTTP Request\n<i>POST /api/service-pages\nCreate new entry</i>"]
        UPDATE_ENTRY["✏️ HTTP Request\n<i>PUT /api/service-pages/{docId}\nUpdate existing entry</i>"]
        PUBLISH["📢 HTTP Request\n<i>POST /api/service-pages/{docId}\n/actions/publish</i>"]
        VERIFY_API["✅ HTTP Request\n<i>GET /api/service-pages\n?filters[slug]&populate=*\nVerify response matches payload</i>"]

        CHECK_EXISTS --> DECIDE
        DECIDE -->|No| CREATE_ENTRY --> PUBLISH
        DECIDE -->|Yes| UPDATE_ENTRY --> PUBLISH
        PUBLISH --> VERIFY_API
    end

    %% ─────────────── STAGE 6: FRONTEND GENERATION ───────────────
    subgraph STAGE6["<b>Stage 6 — Next.js Page Generation</b>"]
        direction TB
        GEN_REDIRECT["⚙️ Code Node\n<i>Generate redirect entry for\nnext.config.mjs\n(old WP URL → new /ae/ URL)</i>"]
        CHECK_DYNAMIC["🔍 Code Node\n<i>Verify dynamic route\n[slug]/page.tsx exists\nor generate static page</i>"]
        GIT_COMMIT["💾 Execute Command\n<i>git add + commit + push\nto feat/ae-migration branch</i>"]
        VERCEL_DEPLOY["🚀 Webhook\n<i>Trigger Vercel preview deploy\nvia deploy hook</i>"]
        WAIT_BUILD["⏳ Wait Node\n<i>Poll Vercel API for\nbuild completion (max 5min)</i>"]

        GEN_REDIRECT --> CHECK_DYNAMIC --> GIT_COMMIT --> VERCEL_DEPLOY --> WAIT_BUILD
    end

    %% ─────────────── STAGE 7: QA & VALIDATION ───────────────
    subgraph STAGE7["<b>Stage 7 — Automated QA & Validation</b>"]
        direction TB
        TEST_301["🔗 HTTP Request\n<i>Verify 301 redirect\nold URL → new URL\n(follow redirects = off)</i>"]
        TEST_200["🌐 HTTP Request\n<i>Verify new page returns 200\nwith correct content</i>"]
        CHECK_META["⚙️ Code Node\n<i>Parse HTML — verify\nmeta title, description,\ncanonical, OG tags</i>"]
        CHECK_JSONLD["⚙️ Code Node\n<i>Extract & validate all\nJSON-LD blocks against\nschema.org specs</i>"]
        LIGHTHOUSE["🔦 Execute Command\n<i>Run Lighthouse CI\nPerf ≥90 Acc ≥95\nBP ≥95 SEO = 100</i>"]
        SCREENSHOT["📸 Execute Command\n<i>Playwright screenshot\ndesktop + mobile</i>"]

        TEST_301 --> TEST_200 --> CHECK_META --> CHECK_JSONLD --> LIGHTHOUSE --> SCREENSHOT
    end

    %% ─────────────── STAGE 8: REPORTING ───────────────
    subgraph STAGE8["<b>Stage 8 — Reporting & Logging</b>"]
        direction TB
        LOG_SUCCESS["📊 Google Sheets / Airtable\n<i>Log: page URL, status,\nLighthouse scores,\ntimestamp, errors</i>"]
        NOTIFY["📨 Send Email / Slack\n<i>Migration summary:\npages done, pages failed,\nscreenshot attachments</i>"]
        NEXT_BATCH["🔄 Loop Back\n<i>Return to Split node\nfor next page in queue</i>"]

        LOG_SUCCESS --> NOTIFY --> NEXT_BATCH
    end

    %% ─────────────── ERROR HANDLING ───────────────
    subgraph ERRORS["<b>⚠️ Error Handling (all stages)</b>"]
        direction TB
        CATCH_ERR["🚨 Error Trigger\n<i>Catch any node failure</i>"]
        LOG_ERR["📋 Google Sheets\n<i>Log error: page URL,\nstage, error message,\ntimestamp</i>"]
        ALERT["🔔 Send Email / Slack\n<i>Alert: migration failed\nfor {page URL} at {stage}</i>"]
        SKIP_PAGE["⏭️ Continue\n<i>Skip failed page,\ncontinue with next</i>"]

        CATCH_ERR --> LOG_ERR --> ALERT --> SKIP_PAGE
    end

    %% ─────────────── CONNECTIONS BETWEEN STAGES ───────────────
    SPLIT --> SCRAPE_PAGE
    MERGE_EXTRACT --> CLASSIFY
    MERGE_EXTRACT --> DOWNLOAD_IMG
    BUILD_PAYLOAD --> CHECK_EXISTS
    GET_IMG_IDS --> BUILD_PAYLOAD
    VERIFY_API --> GEN_REDIRECT
    WAIT_BUILD --> TEST_301
    SCREENSHOT --> LOG_SUCCESS
    NEXT_BATCH -.->|"Loop"| SPLIT
    SKIP_PAGE -.->|"Loop"| SPLIT

    %% ─────────────── STYLING ───────────────
    classDef stageStyle fill:#0B1A2F,stroke:#F97316,stroke-width:2px,color:#F8FAFC
    classDef aiNode fill:#7C3AED,stroke:#F97316,stroke-width:2px,color:#F8FAFC
    classDef httpNode fill:#1E293B,stroke:#64748B,stroke-width:1px,color:#F8FAFC
    classDef codeNode fill:#0F766E,stroke:#14B8A6,stroke-width:1px,color:#F8FAFC
    classDef errorNode fill:#991B1B,stroke:#EF4444,stroke-width:2px,color:#F8FAFC
    classDef triggerNode fill:#F97316,stroke:#0B1A2F,stroke-width:2px,color:#0B1A2F
    classDef decisionNode fill:#1E40AF,stroke:#3B82F6,stroke-width:2px,color:#F8FAFC

    class START triggerNode
    class CLASSIFY,REWRITE_SEO,ENRICH_FAQS aiNode
    class FETCH_SITEMAP,SCRAPE_PAGE,EXTRACT_META,EXTRACT_BODY,EXTRACT_IMAGES,EXTRACT_FAQS,DOWNLOAD_IMG,UPLOAD_STRAPI,CHECK_EXISTS,CREATE_ENTRY,UPDATE_ENTRY,PUBLISH,VERIFY_API,TEST_301,TEST_200,VERCEL_DEPLOY httpNode
    class PARSE_XML,FILTER_AE,SPLIT,EXTRACT_SCHEMA,MAP_SLUG,BUILD_JSONLD,BUILD_PAYLOAD,OPTIMIZE_IMG,GET_IMG_IDS,GEN_REDIRECT,CHECK_DYNAMIC,CHECK_META,CHECK_JSONLD,MERGE_EXTRACT codeNode
    class CATCH_ERR,LOG_ERR,ALERT,SKIP_PAGE errorNode
    class DECIDE decisionNode
